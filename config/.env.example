# totoro-ai — environment variable template (ADR-051)
#
# Copy this to `.env` at the project root and fill in real values.
# `.env` is gitignored (typically a symlink → totoro-config/secrets/ai.env.local).
# Never commit a populated copy.

# --- infrastructure ---
DATABASE_URL=
REDIS_URL=

# --- LLM / model providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Apify Personal API token — Google Maps shared-list import via the
# parseforge/google-maps-shared-list-scraper actor. Optional: when
# unset, Maps list URLs (maps.app.goo.gl/...) short-circuit silently
# with no candidates; the rest of extraction works normally. Get one
# free at https://console.apify.com/account/integrations
APIFY_TOKEN=

# --- observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# --- runtime toggles (optional) ---
# AGENT_ENABLED=true                # set to "false" to kill the agent path with no redeploy
# AGENT_MODEL=                      # ADR-068 — orchestrator option key override
