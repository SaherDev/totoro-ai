DATABASE_URL=
REDIS_URL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Apify Personal API token — Google Maps shared-list import via the
# parseforge/google-maps-shared-list-scraper actor. Optional: when
# unset, Maps list URLs (maps.app.goo.gl/...) short-circuit silently
# with no candidates; the rest of extraction works normally. Get one
# free at https://console.apify.com/account/integrations
APIFY_TOKEN=

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Feature flags
AGENT_ENABLED=true

# Orchestrator selection (ADR-068). Unset = use config/app.yaml
# `models.orchestrator.default`. Valid keys are the option names under
# `models.orchestrator` (e.g. claude-sonnet, claude-haiku, gpt-4o-mini).
# Unknown values log a warning and fall back to the default.
# AGENT_MODEL=
